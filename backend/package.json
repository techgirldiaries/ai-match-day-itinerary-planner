    "dotenv": "^16.4.5",
    "hono": "^4.12.18",
    "sql.js": "^1.10.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@hono/node-server": "^1.19.13",
    "@types/node": "^24.5.1",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.7",
    "terser": "^5.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.1"
  }
