{
  "name": "ltfc-backend",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Match-Day Itinerary Planner Backend - Feature 2+ API Server",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
