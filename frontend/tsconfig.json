{
  "extends": "../.config/typescript/tsconfig.frontend.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "react": [
        "../node_modules/preact/compat/"
      ],
      "react-dom": [
        "../node_modules/preact/compat/"
      ]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*"
  ]
}