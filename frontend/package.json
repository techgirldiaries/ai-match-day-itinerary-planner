{
  "name": "ltfc-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Match-Day Itinerary Planner Frontend - Preact + Vite",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --testNamePattern=unit --coverage",
    "test:integration": "vitest run --testNamePattern=integration --coverage",
    "test:e2e": "playwright test",
    "test:performance": "vitest run --testNamePattern=performance"
  },
  "dependencies": {
    "@preact/signals": "^2.3.1",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@relevanceai/sdk": "latest",
    "@tailwindcss/vite": "^4.1.13",
    "lucide-preact": "^0.349.0",
    "marked": "^17.0.6",
    "preact": "^10.26.9",
    "swr": "^2.3.6",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@playwright/test": "^1.44.0",
    "@preact/preset-vite": "^2.10.2",
    "@tailwindcss/oxide": "^4.2.2",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/node": "^24.5.1",
    "axios": "^1.6.0",
    "baseline-browser-mapping": "^2.10.0",
    "identity-obj-proxy": "^3.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.1"
  }
}
