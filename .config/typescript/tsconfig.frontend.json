{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "@/*": [
        "../../frontend/src/*"
      ],
      "react": [
        "../../node_modules/preact/compat/"
      ],
      "react-dom": [
        "../../node_modules/preact/compat/"
      ]
    }
  },
  "include": [
    "../../node_modules/vite/client.d.ts",
    "../../frontend/**/*"
  ]
}